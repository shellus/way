# 备份规则配置
# 备份目的地见 repositories.yaml
# 复制为 rules.yaml 并根据实际情况修改

# 全局默认配置
defaults:
  # schedule 使用 node-cron 语法（分 时 日 月 周）
  # 设置为 false 表示不自动调度，只允许手动执行 way backup
  # 支持多种表达方式：
  #   "0 */2 * * *"      - 每 2 小时
  #   "0 9,15,21 * * *"  - 每天 9:00、15:00、21:00
  #   "0 9-17 * * 1-5"   - 工作日 9:00-17:00 每小时
  schedule: false
  retention:
    keep_daily: 7
    keep_weekly: 4
    keep_monthly: 6

# Uptime Kuma 通知（备份完成后推送状态）
uptime_kuma:
  push_url: "https://uptime.example.com/api/push/xxxxx"

# 备份项目
projects:
  data:
    description: 数据目录
    paths:
      - /path/to/data
    schedule: "0 */2 * * *"  # 每 2 小时自动备份
    excludes:
      - cache
      - tmp

  config:
    description: 配置文件
    paths:
      - /home/user/.config
      - /home/user/.ssh
    schedule: "0 3 * * *"  # 覆盖默认，每天凌晨 3 点
    excludes: []

  archive:
    description: 历史归档
    paths:
      - /archive
    schedule: false  # 只手动触发：way backup archive
    retention:
      keep_weekly: 8
      keep_monthly: 12
      keep_yearly: 3
    excludes: []

  data_deps:
    description: 手动备份 /path/to/data 下所有依赖目录
    paths:
      - /path/to/data
    include_dirs:
      - node_modules
      - vendor
    schedule: false  # 只手动触发：way backup data_deps

# 全局排除规则 - 适用于所有项目
global_excludes:
  # 包管理
  - node_modules
  - .venv
  - venv
  - __pycache__
  - "*.pyc"
  - vendor

  # 缓存
  - .cache

  # 构建产物
  - dist
  - .next

  # IDE配置
  - .idea
  - .vscode

  # 临时文件
  - "*.log"
  - "*.tmp"
  - "*.swp"

# 维护任务（可选）
maintenance:
  prune:
    schedule: "0 4 * * 0"  # 每周日凌晨 4 点清理
  check:
    schedule: false        # 不执行
