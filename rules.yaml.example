# 备份规则配置
# 备份目的地见 repositories.yaml
# 复制为 rules.yaml 并根据实际情况修改

# 全局默认配置
defaults:
  schedule: "0 */2 * * *"  # 默认每 2 小时
  retention:
    keep_daily: 7
    keep_weekly: 4
    keep_monthly: 6

# Uptime Kuma 通知（备份完成后推送状态）
uptime_kuma:
  push_url: "https://uptime.example.com/api/push/xxxxx"

# 备份项目
projects:
  data:
    description: 数据目录
    paths:
      - /path/to/data
    excludes:
      - cache
      - tmp

  config:
    description: 配置文件
    paths:
      - /home/user/.config
      - /home/user/.ssh
    schedule: "0 3 * * *"  # 覆盖默认，每天凌晨 3 点
    excludes: []

  archive:
    description: 历史归档
    paths:
      - /archive
    schedule: "0 2 * * 0"  # 每周日凌晨 2 点
    retention:
      keep_weekly: 8
      keep_monthly: 12
      keep_yearly: 3
    excludes: []

# 全局排除规则 - 适用于所有项目
global_excludes:
  # 包管理
  - node_modules
  - .venv
  - venv
  - __pycache__
  - "*.pyc"
  - vendor

  # 缓存
  - .cache

  # 构建产物
  - dist
  - .next

  # IDE配置
  - .idea
  - .vscode

  # 临时文件
  - "*.log"
  - "*.tmp"
  - "*.swp"

# 维护任务（可选）
maintenance:
  prune:
    schedule: "0 4 * * 0"  # 每周日凌晨 4 点清理
  check:
    schedule: ""           # 留空不执行
